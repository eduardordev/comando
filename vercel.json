{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "test -f package.json && grep -q '\"workspaces\"' package.json && npm install --include=dev || npm --prefix .. install --include=dev",
  "buildCommand": "test -f scripts/vercel-build.sh && bash scripts/vercel-build.sh || bash ../scripts/vercel-build.sh",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
