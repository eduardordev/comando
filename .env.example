# Copia a server/.env para desarrollo local
# cp server/.env.example server/.env

# Variables para Vercel (Project Settings → Environment Variables):
#
# DATABASE_URL       → libsql://tu-db.turso.io  o https://tu-db.turso.io
# TURSO_DATABASE_URL → igual que DATABASE_URL (runtime de la API)
# TURSO_AUTH_TOKEN   → token de Turso
#
# Recordatorios por correo (Resend):
# RESEND_API_KEY       → API key de Resend
# REMINDER_EMAIL_TO    → correo al que se envían los recordatorios (debe ser tu propio
#                         correo registrado en Resend si usas el remitente de pruebas)
# REMINDER_EMAIL_FROM  → remitente, ej. "Comando del Día <onboarding@resend.dev>"
#                         (o tu dominio verificado en Resend)
# APP_URL              → URL pública de la app, ej. https://comando-del-dia.vercel.app
# CRON_SECRET          → secreto que Vercel envía como "Authorization: Bearer <valor>"
#                         al disparar el cron; protege el endpoint de envíos manuales
