# Copia a server/.env para desarrollo local
# cp server/.env.example server/.env

# Variables para Vercel (Project Settings → Environment Variables):
#
# DATABASE_URL       → libsql://tu-db.turso.io  o https://tu-db.turso.io
# TURSO_DATABASE_URL → igual que DATABASE_URL (runtime de la API)
# TURSO_AUTH_TOKEN   → token de Turso
