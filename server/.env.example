# Local (SQLite en disco) — usado por prisma migrate
DATABASE_URL="file:../data/comando.db"

# Producción Turso (runtime de la API + seed remoto)
# TURSO_DATABASE_URL="libsql://comando-del-dia-eduardordev.aws-us-east-2.turso.io"
# TURSO_AUTH_TOKEN="tu-token"

# Para Turso usa (desde PowerShell o WSL):
#   $env:TURSO_DATABASE_URL="libsql://..."
#   $env:TURSO_AUTH_TOKEN="..."
#   npm run db:migrate:turso
#
# En Vercel, las migraciones se aplican automáticamente en el build
# si TURSO_DATABASE_URL y TURSO_AUTH_TOKEN están configurados.
